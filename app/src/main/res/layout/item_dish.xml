<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Dish Image -->
        <ImageView
            android:id="@+id/dishImageView"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/circle_orange_background"
            android:padding="8dp"
            android:src="@drawable/ic_dish_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Dish Name -->
        <TextView
            android:id="@+id/dishNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Dish Name"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/favoriteImageView"
            app:layout_constraintStart_toEndOf="@id/dishImageView"
            app:layout_constraintTop_toTopOf="@id/dishImageView" />

        <!-- Dish Description -->
        <TextView
            android:id="@+id/dishDescriptionTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Description"
            android:textColor="#666666"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/dishNameTextView"
            app:layout_constraintStart_toStartOf="@id/dishNameTextView"
            app:layout_constraintTop_toBottomOf="@id/dishNameTextView" />

        <!-- Difficulty Level -->
        <TextView
            android:id="@+id/difficultyTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/difficulty_background"
            android:padding="4dp"
            android:text="easy"
            android:textColor="#FF6B35"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="@id/dishNameTextView"
            app:layout_constraintTop_toBottomOf="@id/dishDescriptionTextView" />

        <!-- Favorite Icon -->
        <ImageView
            android:id="@+id/favoriteImageView"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bookmark_border"
            android:tint="#FF6B35"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/dishImageView" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
